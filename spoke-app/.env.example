# ─── Backend (server-side only, never expose to browser) ─────────────────────

# OpenAI — Whisper transcription
OPENAI_API_KEY=sk-...

# Anthropic — Claude content formatting
ANTHROPIC_API_KEY=sk-...

# Supabase — service role key (admin, server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=


# ─── Frontend (safe to expose, prefixed with VITE_) ───────────────────────────

# Supabase — public anon key (used in the browser via supabase.js)
VITE_SUPABASE_URL=
